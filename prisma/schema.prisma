generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CABINET
  USER
}

model Cabinet {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  users User[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  categories Category[]
  demands    Demand[]

  @@map("cabinets")
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  role     Role    @default(USER)
  isActive Boolean @default(true)

  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  cabinetId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  demands   Demand[]

  @@map("users")
}

enum DemandStatus {
  SUBMITTED
  IN_ANALYSIS
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model Category {
  id       String  @id @default(uuid())
  name     String
  isActive Boolean @default(true)

  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  cabinetId String

  demands Demand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Demand {
  id          String       @id @default(uuid())
  title       String
  description String
  status      DemandStatus @default(SUBMITTED)

  latitude  Float?
  longitude Float?
  address   String?

  googlePlaceId String?

  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  cabinetId String

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("demands")
}
