generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CABINET
  USER
}

model Cabinet {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  users User[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  categories Category[]
  demands    Demand[]
  results    Result[]

  @@map("cabinets")
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  role     Role    @default(USER)
  isActive Boolean @default(true)

  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  cabinetId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  demands         Demand[]        @relation("ReporterDemands")
  assignedDemands Demand[]        @relation("AssigneeDemands")
  comments        DemandComment[]

  @@map("users")
}

enum DemandStatus {
  SUBMITTED
  IN_ANALYSIS
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model Category {
  id       String  @id @default(uuid())
  name     String
  isActive Boolean @default(true)

  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  cabinetId String

  demands Demand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Demand {
  id          String       @id @default(uuid())
  title       String
  description String
  status      DemandStatus @default(SUBMITTED)

  latitude  Float?
  longitude Float?
  address   String?

  googlePlaceId String?

  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  cabinetId String

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  reporter   User   @relation("ReporterDemands", fields: [reporterId], references: [id])
  reporterId String

  assignee   User?   @relation("AssigneeDemands", fields: [assigneeId], references: [id])
  assigneeId String?

  evidences DemandEvidence[]
  comments  DemandComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  result    Result?

  @@map("demands")
}

model DemandEvidence {
  id       String @id @default(uuid())
  url      String
  key      String
  mimeType String

  demand   Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  demandId String

  createdAt DateTime @default(now())

  @@map("demand_evidences")
}

model DemandComment {
  id      String @id @default(uuid())
  content String @db.Text

  demand   Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  demandId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("demand_comments")
}

enum ResultType {
  INFRASTRUCTURE
  SOCIAL
  LEGISLATIVE
  OTHER
}

enum ImageType {
  BEFORE
  AFTER
  GENERAL
}

model ResultImage {
  id       String    @id @default(uuid())
  url      String
  key      String
  type     ImageType @default(GENERAL)
  isActive Boolean   @default(true)

  resultId String
  result   Result @relation(fields: [resultId], references: [id], onDelete: Cascade)
}

model Result {
  id          String     @id @default(uuid())
  title       String
  description String     @db.Text
  date        DateTime   @default(now())
  type        ResultType @default(INFRASTRUCTURE)
  isActive    Boolean    @default(true)
  isPublic    Boolean    @default(false)

  cabinet   Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  cabinetId String

  demandId String? @unique
  demand   Demand? @relation(fields: [demandId], references: [id])

  images ResultImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("results")
}
